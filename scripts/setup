#!/usr/bin/env bash
# Wire this checkout into the devcontainer's baked-in Home Assistant install.
#
# The devcontainer base image (see .devcontainer/devcontainer.json) is the
# official homeassistant/home-assistant image, pinned to a dev-branch
# nightly. hacs.json's `homeassistant` floor is 2026.8.0b0 (the LLM tools
# platform, see llm_api.py) — not on PyPI as a release yet, and HA doesn't
# publish dev-branch nightlies to PyPI at all, only as Docker Hub image
# tags. Pinning the devcontainer image to a nightly tag (verified against
# real homeassistant.components.llm) is how we get 2026.8 today; move the
# image tag to a release tag once 2026.8.0b0 ships.
#
# Unlike a generic Python devcontainer, the image already bundles HA core,
# the frontend, and every native/runtime dependency default_config needs
# (ffmpeg, go2rtc, PyTurboJPEG, aioesphomeapi, hassil, home-assistant-intents)
# — so there is nothing to apt-get or download here, only this integration's
# own runtime deps plus dev-only tools.
set -euo pipefail

cd "$(dirname "$0")/.."

pip3 install --no-cache-dir --quiet \
  "curl_cffi>=0.7.0" \
  "beautifulsoup4>=4.12.0" \
  ruff \
  colorlog

mkdir -p config
if [ ! -f config/configuration.yaml ]; then
  cat > config/configuration.yaml <<'YAML'
# ha_korean_public_data devcontainer configuration.
# Identity values distinguish this dev instance from any production
# Home Assistant on the host network. Adjust latitude/longitude/timezone
# for your locale.
homeassistant:
  name: kr_public_data Dev
  latitude: 37.5665
  longitude: 126.9780
  elevation: 38
  unit_system: metric
  time_zone: Asia/Seoul
  external_url: "http://kr-public-data-dev:8123"
  internal_url: "http://kr-public-data-dev:8123"

default_config:

http:
  server_port: 8123

logger:
  default: info
  logs:
    custom_components.kr_public_data: debug
YAML
fi

# Symlink the integration into HA's config dir so edits hot-reload.
mkdir -p config/custom_components
ln -sfn "$PWD/custom_components/kr_public_data" config/custom_components/kr_public_data

echo "Setup complete. Run scripts/develop to start Home Assistant."
